
# ══════════════════════════════════════════════════════════════════════
# AdStrike — Environment Configuration Template
# Copy this file to .env and fill in your values.
# AUTHORISED PENETRATION TESTING & RED TEAM ENGAGEMENTS ONLY
# ══════════════════════════════════════════════════════════════════════

# ── TARGET ─────────────────────────────────────────────────────────────
DC_IP=
DOMAIN=
DC_FQDN=
ENGAGEMENT_NAME=

# ── CREDENTIALS (choose one auth method) ───────────────────────────────
USERNAME=
PASSWORD=
# NT_HASH=aad3b435b********ad3b435b51404ee:818**********d4
USE_KERBEROS=false
# KRB5_CCACHE=/tmp/krb5cc_your.ccache

# ── ATTACKER ───────────────────────────────────────────────────────────
ATTACKER_IP=
ATTACKER_IFACE=tun0

# ── AI AGENT (optional) ────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...    # Only needed for Claude backend
# OLLAMA_HOST=http://127.0.0.1:11434

# ── OUTPUT ─────────────────────────────────────────────────────────────
OUTPUT_DIR=output
ADSTRIKE_SHOW_SECRETS=false
